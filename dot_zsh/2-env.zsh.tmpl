# 环境变量配置

# 语言环境
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# 编辑器配置
export EDITOR='vim'
export VISUAL='vim'

# 历史记录配置
export HISTSIZE=10000
export SAVEHIST=10000
export HISTFILE="$HOME/.zsh_history"
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS

# SSH Agent 配置 (Secretive)
_secretive_sock="{{ .chezmoi.homeDir }}/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/socket.ssh"
if [[ -S "$_secretive_sock" ]]; then
    export SSH_AUTH_SOCK="$_secretive_sock"
fi
unset _secretive_sock
